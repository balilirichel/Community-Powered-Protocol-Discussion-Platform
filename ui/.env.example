# ─── Laravel API ********************─────
# Base URL of the Laravel backend (no trailing slash).
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# ─── Typesense Direct-Client Config ───────────────────────────────────────────
# These are read by src/typesense/typesenseClient.ts to build the JS client.
#
# IMPORTANT: The VITE_ prefix is REQUIRED. Vite strips all env vars that don't
# start with VITE_ from the browser bundle for security reasons.
#
# SECURITY NOTE: Set VITE_TYPESENSE_API_KEY to a *search-only* (read-only) key
# that you generate in the Typesense dashboard. NEVER use the admin key here.
VITE_TYPESENSE_HOST=127.0.0.1
VITE_TYPESENSE_PORT=8108
VITE_TYPESENSE_PROTOCOL=http
VITE_TYPESENSE_API_KEY=<your_search_only_api_key>
